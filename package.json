{
  "name": "devin-mind",
  "version": "1.0.0",
  "description": "Workflow management application for Devin AI automation",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder",
    "test": "jest",
    "lint": "eslint src/ electron/ --ext .js"
  },
  "keywords": [
    "workflow",
    "automation",
    "devin",
    "ai",
    "electron"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "@jest/globals": "^29.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "markdown-it": "^13.0.0"
  },
  "build": {
    "appId": "com.yourcompany.devin-mind",
    "productName": "Devin Mind",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ]
  }
}